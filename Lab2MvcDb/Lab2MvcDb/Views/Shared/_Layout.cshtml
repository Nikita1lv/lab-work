<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Лабораторная работа №2</title>
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
</head>
<body>
    <header class="topbar">
        <div class="container">
            <h1>Лабораторная работа №2</h1>
            <p>ASP.NET MVC: несколько экземпляров модели и пользовательские вспомогательные методы</p>
        </div>
    </header>

    <nav class="menu container">
        @Html.ActionLink("Текущая запись", "Details", "Database")
        @Html.ActionLink("Все записи", "All", "Database")
        @Html.ActionLink("Вспомогательные методы", "AllWithHelpers", "Database")
        @Html.ActionLink("Добавить", "Create", "Database")
    </nav>

    <main class="container card">
        @RenderBody()
    </main>
</body>
</html>
